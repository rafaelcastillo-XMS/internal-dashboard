# Supabase — copy this file to .env and fill in your values
VITE_SUPABASE_URL=https://megfomcoqiyykdemwnrt.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Notion client sync — server-side only; never prefix these with VITE_
NOTION_API_KEY=ntn_your_integration_token_here
NOTION_DATA_SOURCE_ID=your_clients_data_source_id_here

# Anthropic — Claude AI (Ask AI Anything modal)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ahrefs — server-side only; never prefix this variable with VITE_
AHREFS_API_KEY=your_ahrefs_api_key_here

# GitHub — optional, required when XMS-Ai/company-skills is private
GITHUB_TOKEN=your_github_token_here
COMPANY_SKILLS_REPO=XMS-Ai/company-skills
